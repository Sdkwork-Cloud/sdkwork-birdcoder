# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BirdCoder local user center mode.
# local: built-in sqlite plus_user center with the default dev quick-login account.
# sdkwork-app-api: delegate login/profile/session exchange to the external app-api/app-sdk user center.
BIRDCODER_USER_CENTER_LOGIN_PROVIDER=local

# Optional provider key override exposed by /api/app/v1/auth/config.
BIRDCODER_USER_CENTER_PROVIDER_KEY=local

# Default local bootstrap password for the dev quick-login account:
# local-default@sdkwork-birdcoder.local / dev123456
BIRDCODER_LOCAL_BOOTSTRAP_PASSWORD=dev123456

# Configure when BIRDCODER_USER_CENTER_LOGIN_PROVIDER=sdkwork-app-api
# BIRDCODER_USER_CENTER_APP_API_BASE_URL=http://127.0.0.1:8080
# BIRDCODER_USER_CENTER_APP_API_TIMEOUT_MS=8000
