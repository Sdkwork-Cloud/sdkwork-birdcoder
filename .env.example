# Canonical source profiles live in etc/topology. This file documents only
# safe local overrides and contains no production credentials.
#
# Deployment profile and runtime target are independent. BirdCoder supports
# standalone or cloud deployment; desktop is the default local PC runtime.
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
SDKWORK_BIRDCODER_ENVIRONMENT=development
VITE_SDKWORK_BIRDCODER_ENVIRONMENT=development
SDKWORK_BIRDCODER_RUNTIME_TARGET=desktop
VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET=desktop

# BirdCoder owns only the four authenticated System operations at this
# application ingress. Set an override only for an explicit local endpoint.
# SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240
# VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240

# Agents, Skills, IM, IAM, Drive, Documents, Prompts, Membership, and other
# dependency SDKs use the platform gateway, not BirdCoder-owned API paths.
# SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
# VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900

# Optional local auth form prefill. Identity still comes from IAM APIs.
# VITE_BIRDCODER_AUTH_DEV_PREFILL_ENABLED=true
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_EMAIL=you@example.test
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_PASSWORD=your-dev-password
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_LOGIN_METHOD=password

# SDKWork private bootstrap credential. Tracked templates keep it blank.
SDKWORK_ACCESS_TOKEN=
