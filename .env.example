# BirdCoder IAM deployment mode used by the pnpm wrappers.
# desktop-local: Tauri embeds the coding server and uses the local sqlite user center.
# server-private: desktop/web clients talk to a private BirdCoder server that uses the local user center.
# cloud-saas: desktop/web clients talk to a BirdCoder server that delegates IAM to sdkwork-cloud-app-api.
BIRDCODER_IAM_DEPLOYMENT_MODE=desktop-local

# Canonical user-center provider selector consumed by the BirdCoder server.
# builtin-local: embedded sqlite plus_user authority for private deployments.
# sdkwork-cloud-app-api: delegate login/profile/session handling to the shared cloud app-api authority.
# external-user-center: delegate IAM to a third-party header-based authority bridge.
# All three provider kinds stay behind the same BirdCoder facade routes such as
# /app/v3/api/auth/*, /app/v3/api/iam/users/current, and /app/v3/api/billing/vip/info.
# The standardized external-provider wrappers map to:
# pnpm dev:external
# pnpm web:dev:external
# pnpm tauri:dev:external
# pnpm desktop:dev:external
# pnpm server:dev:external
SDKWORK_USER_CENTER_MODE=builtin-local
# The pnpm wrappers mirror this to VITE_SDKWORK_USER_CENTER_MODE so
# web and desktop hosts can bind the canonical provider before /app/v3/api/auth/config
# returns its authoritative metadata.

# Optional canonical provider key override exposed by /app/v3/api/auth/config.
# SDKWORK_USER_CENTER_PROVIDER_KEY=sdkwork-birdcoder-local

# Remote BirdCoder coding-server base URL used by desktop/web clients in server-private or cloud-saas mode.
# If omitted, the wrappers default to http://127.0.0.1:10240 for client-facing private/cloud commands.
# Desktop build commands for private/cloud mode require one of these values explicitly.
# BIRDCODER_API_BASE_URL=http://127.0.0.1:10240
# VITE_BIRDCODER_API_BASE_URL=http://127.0.0.1:10240

# Optional sqlite override. When omitted, the wrappers select a mode-specific sqlite file:
# desktop-local -> packages/sdkwork-birdcoder-desktop/.local/sdkwork-birdcoder-desktop-local.sqlite3
# server-private -> packages/sdkwork-birdcoder-server/.local/sdkwork-birdcoder-server-private.sqlite3
# cloud-saas -> packages/sdkwork-birdcoder-server/.local/sdkwork-birdcoder-cloud-saas.sqlite3
# BIRDCODER_CODING_SERVER_SQLITE_FILE=D:/data/sdkwork-birdcoder/birdcoder.sqlite3

# Local bootstrap user for the builtin-local user-center provider.
# This account is seeded automatically on first startup for desktop-local and server-private modes.
SDKWORK_USER_CENTER_LOCAL_BOOTSTRAP_EMAIL=local-default@sdkwork-user-center.local
SDKWORK_USER_CENTER_LOCAL_BOOTSTRAP_PHONE=13800000000
SDKWORK_USER_CENTER_LOCAL_BOOTSTRAP_PASSWORD=dev123456

# Development-only fixed verification code for local email/phone verification flows.
# The pnpm dev wrappers default this to 123456 for desktop-local and server-private.
SDKWORK_USER_CENTER_LOCAL_VERIFY_CODE_FIXED=123456

# Optional absolute or sqlite-relative starter project root for the builtin-local sample workspace.
# When omitted, BirdCoder seeds a deterministic absolute path beside the sqlite authority file:
# <sqlite-dir>/bootstrap-projects/<sqlite-file-stem>/project-default
# BIRDCODER_LOCAL_BOOTSTRAP_PROJECT_ROOT=D:/data/sdkwork-birdcoder/bootstrap/project-default

# Local OAuth providers exposed by the builtin-local user-center authority.
# BirdCoder uses the same /app/v3/api/auth/oauth_authorization_urls and /app/v3/api/auth/oauth_sessions facade
# in desktop-local and server-private modes; the local authority signs a short-lived authorization
# code and redirects back into the shared sdkwork-appbase auth surface.
# Set an empty value to disable local social-login buttons.
SDKWORK_USER_CENTER_LOCAL_OAUTH_PROVIDERS=wechat,douyin,github
# Optional provider-specific local OAuth sample identities:
# SDKWORK_USER_CENTER_LOCAL_OAUTH_WECHAT_NAME=WeChat BirdCoder
# SDKWORK_USER_CENTER_LOCAL_OAUTH_WECHAT_EMAIL=wechat@oauth.sdkwork-user-center.local
# SDKWORK_USER_CENTER_LOCAL_OAUTH_DOUYIN_NAME=Douyin BirdCoder
# SDKWORK_USER_CENTER_LOCAL_OAUTH_GITHUB_NAME=GitHub BirdCoder

# Development quick-login prefill for the shared sdkwork-appbase auth surface.
# The BirdCoder sample defaults to the local bootstrap account in development/test when builtin-local is active.
# For cloud-saas, override these values with a real remote test account when needed.
VITE_BIRDCODER_AUTH_DEV_PREFILL_ENABLED=true
VITE_BIRDCODER_AUTH_DEV_DEFAULT_ACCOUNT=local-default@sdkwork-user-center.local
VITE_BIRDCODER_AUTH_DEV_DEFAULT_EMAIL=local-default@sdkwork-user-center.local
VITE_BIRDCODER_AUTH_DEV_DEFAULT_PHONE=13800000000
VITE_BIRDCODER_AUTH_DEV_DEFAULT_PASSWORD=dev123456
VITE_BIRDCODER_AUTH_DEV_DEFAULT_LOGIN_METHOD=password

# sdkwork-cloud-app-api integration settings used when
# BIRDCODER_IAM_DEPLOYMENT_MODE=cloud-saas or
# SDKWORK_USER_CENTER_MODE=sdkwork-cloud-app-api
# SDKWORK_USER_CENTER_APP_API_BASE_URL=https://app-api.sdkwork.com
# SDKWORK_USER_CENTER_APP_API_TIMEOUT_MS=8000
# SDKWORK_USER_CENTER_APP_ID=sdkwork-user-center
# SDKWORK_USER_CENTER_SECRET_ID=user-center-desktop
# SDKWORK_USER_CENTER_SHARED_SECRET=replace-with-shared-secret
# Optional cloud social-login providers exposed through the canonical BirdCoder facade.
# Set an empty value to disable social login for cloud mode.
# SDKWORK_USER_CENTER_APP_API_OAUTH_PROVIDERS=wechat,douyin,github

# Third-party external user-center header bridge settings used when
# SDKWORK_USER_CENTER_MODE=external-user-center
# SDKWORK_USER_CENTER_EXTERNAL_ID_HEADER=x-birdcoder-user-id
# SDKWORK_USER_CENTER_EXTERNAL_EMAIL_HEADER=x-birdcoder-user-email
# SDKWORK_USER_CENTER_EXTERNAL_NAME_HEADER=x-birdcoder-user-name
# SDKWORK_USER_CENTER_EXTERNAL_AVATAR_HEADER=x-birdcoder-user-avatar

# Optional engine/application secrets retained from the existing workspace template.
# GEMINI_API_KEY=MY_GEMINI_API_KEY
# APP_URL=MY_APP_URL
