# SDKWork BirdCoder 开发环境变量模板
# 复制为 .env 并填充你的环境特定值
# 开发环境的本地数据库密码允许明文
# 生产环境必须通过安全渠道（密钥管理服务/CI secrets）传递

# =============================================================================
# IAM 部署模式
# =============================================================================
# desktop-local: Tauri 嵌入 coding server + 本地 IAM
# server-private: 桌面/Web → 私有 BirdCoder 服务器
# cloud-saas: 桌面/Web → BirdCoder 服务器 + SDKWork 云端 IAM

# SDKWork IAM 模式（local / private / cloud）
# SDKWork application runtime profile. Deployment profile values are only
# standalone or cloud; runtime target is tracked separately.
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
SDKWORK_BIRDCODER_ENVIRONMENT=development
VITE_SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_BIRDCODER_ENVIRONMENT=development
SDKWORK_BIRDCODER_RUNTIME_TARGET=desktop
VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET=desktop

# =============================================================================
# 远程 API 地址（server-private / cloud-saas 模式必需）
# =============================================================================
# BIRDCODER_API_BASE_URL=http://127.0.0.1:10240
# VITE_BIRDCODER_API_BASE_URL=http://127.0.0.1:10240

# =============================================================================
# SQLite 数据文件（可选覆盖）
# =============================================================================
# 省略时各模式使用默认路径：
#   desktop-local → apps/.../pc-desktop/.local/*-desktop-local.sqlite3
#   server-private → apps/.../pc-server/.local/*-server-private.sqlite3
#   cloud-saas → apps/.../pc-server/.local/*-cloud-saas.sqlite3
# BIRDCODER_CODING_SERVER_SQLITE_FILE=D:/data/sdkwork-birdcoder/birdcoder.sqlite3

# =============================================================================
# IAM Web 框架环境（本地开发必需）
# =============================================================================
# "dev" 启用宽松 CORS（allow_all_origins）用于本地开发。
# 不设置时默认 "prod"，IAM 路由（/app/v3/api/oauth/* 等）会拒绝所有跨域请求。
SDKWORK_IM_ENVIRONMENT=dev
# 以下两项使 Rust 服务端 allows_dev_authentication_fallback() 返回 true，
# 跳过 IAM 权限目录未预配时的 manifest 权限检查（如 SQLite 本地数据库）。
# 见 sdkwork-iam-web-adapter dev_runtime.rs / production_runtime.rs。
SDKWORK_ENV=dev
SDKWORK_ENVIRONMENT=development

# =============================================================================
# Agents 管理存储（本地开发必需）
# =============================================================================
# 本地开发使用内存仓库，避免需要独立的 Agents PostgreSQL 实例。
# 生产环境应删除此项并配置 SDKWORK_AGENTS_STORE_DATABASE_URL。
SDKWORK_AGENTS_DEV_AUTH_BYPASS=true

# =============================================================================
# 开发辅助（仅开发模式启用）
# =============================================================================
# 本地邮箱/短信验证码开发固定值
SDKWORK_IAM_DEV_FIXED_VERIFY_CODE=123456

# 开发登录表单预填（可选；身份仍来自 register/login API）
# VITE_BIRDCODER_AUTH_DEV_PREFILL_ENABLED=true
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_EMAIL=you@example.test
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_PASSWORD=your-dev-password
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_LOGIN_METHOD=password

# =============================================================================
# 本地引导项目根目录
# =============================================================================
# 省略时 BirdCoder 在 SQLite 同级目录创建确定性路径
# BIRDCODER_LOCAL_BOOTSTRAP_PROJECT_ROOT=D:/data/sdkwork-birdcoder/bootstrap/project-default

# =============================================================================
# OAuth 开发 Provider
# =============================================================================
SDKWORK_IAM_OAUTH_PROVIDERS=wechat,douyin,github
# SDKWORK_IAM_OAUTH_WECHAT_NAME=WeChat BirdCoder
# SDKWORK_IAM_OAUTH_WECHAT_EMAIL=wechat@oauth.sdkwork-iam.local
# SDKWORK_IAM_OAUTH_DOUYIN_NAME=Douyin BirdCoder
# SDKWORK_IAM_OAUTH_GITHUB_NAME=GitHub BirdCoder

# =============================================================================
# SDKWork 云端 IAM（仅 cloud-saas 模式）
# =============================================================================
# SDKWORK_IAM_APP_API_BASE_URL=https://app-api.sdkwork.com
# SDKWORK_IAM_APP_API_TIMEOUT_MS=8000
# SDKWORK_IAM_APP_ID=sdkwork-birdcoder
# SDKWORK_IAM_SECRET_ID=birdcoder-desktop
# SDKWORK_IAM_SHARED_SECRET=replace-with-shared-secret
# SDKWORK_IAM_APP_API_OAUTH_PROVIDERS=wechat,douyin,github

# =============================================================================
# PostgreSQL（本地开发）
# =============================================================================
# 本机开发推荐通过 WSL 或 Docker 运行 PostgreSQL
# 生产环境通过容器/编排平台注入，不在 .env 中硬编码
# 见 etc/topology/ 获取不同部署模式的完整配置
# SDKWORK_IAM_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dbname?sslmode=disable
