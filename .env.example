# BirdCoder IAM deployment mode used by the pnpm wrappers.
# desktop-local: Tauri embeds the coding server and uses local SDKWork IAM.
# server-private: desktop/web clients talk to a private BirdCoder server.
# cloud-saas: desktop/web clients talk to a BirdCoder server backed by SDKWork cloud IAM.
BIRDCODER_IAM_DEPLOYMENT_MODE=desktop-local

# Standard SDKWork IAM mode consumed by BirdCoder server and clients.
# local: single-machine local development.
# private: private BirdCoder server deployment.
# cloud: SDKWork cloud app-api IAM deployment.
SDKWORK_IAM_MODE=local
VITE_SDKWORK_DEPLOYMENT_MODE=local

# Remote BirdCoder coding-server base URL used by desktop/web clients in server-private
# or cloud-saas mode. Desktop build commands for remote modes require an explicit value.
# BIRDCODER_API_BASE_URL=http://127.0.0.1:10240
# VITE_BIRDCODER_API_BASE_URL=http://127.0.0.1:10240

# Optional sqlite override. When omitted, the wrappers select a mode-specific sqlite file:
# desktop-local -> packages/sdkwork-birdcoder-desktop/.local/sdkwork-birdcoder-desktop-local.sqlite3
# server-private -> packages/sdkwork-birdcoder-server/.local/sdkwork-birdcoder-server-private.sqlite3
# cloud-saas -> packages/sdkwork-birdcoder-server/.local/sdkwork-birdcoder-cloud-saas.sqlite3
# BIRDCODER_CODING_SERVER_SQLITE_FILE=D:/data/sdkwork-birdcoder/birdcoder.sqlite3

# Local SDKWork IAM bootstrap account for desktop-local and server-private development.
SDKWORK_IAM_LOCAL_BOOTSTRAP_EMAIL=local-default@sdkwork-iam.local
SDKWORK_IAM_LOCAL_BOOTSTRAP_PHONE=13800000000
SDKWORK_IAM_LOCAL_BOOTSTRAP_PASSWORD=dev123456

# Development-only fixed verification code for local email/phone verification flows.
SDKWORK_IAM_LOCAL_VERIFY_CODE_FIXED=123456

# Optional absolute or sqlite-relative starter project root for the local sample workspace.
# When omitted, BirdCoder seeds a deterministic absolute path beside the sqlite authority file:
# <sqlite-dir>/bootstrap-projects/<sqlite-file-stem>/project-default
# BIRDCODER_LOCAL_BOOTSTRAP_PROJECT_ROOT=D:/data/sdkwork-birdcoder/bootstrap/project-default

# Optional local OAuth sample providers exposed through the standard IAM auth routes.
SDKWORK_IAM_LOCAL_OAUTH_PROVIDERS=wechat,douyin,github
# SDKWORK_IAM_LOCAL_OAUTH_WECHAT_NAME=WeChat BirdCoder
# SDKWORK_IAM_LOCAL_OAUTH_WECHAT_EMAIL=wechat@oauth.sdkwork-iam.local
# SDKWORK_IAM_LOCAL_OAUTH_DOUYIN_NAME=Douyin BirdCoder
# SDKWORK_IAM_LOCAL_OAUTH_GITHUB_NAME=GitHub BirdCoder

# Development quick-login prefill for the shared SDKWork IAM auth surface.
# These VITE_ prefixed values are embedded in the client bundle and are only for dev/test.
VITE_BIRDCODER_AUTH_DEV_PREFILL_ENABLED=true
VITE_BIRDCODER_AUTH_DEV_DEFAULT_ACCOUNT=local-default@sdkwork-iam.local
VITE_BIRDCODER_AUTH_DEV_DEFAULT_EMAIL=local-default@sdkwork-iam.local
VITE_BIRDCODER_AUTH_DEV_DEFAULT_PHONE=13800000000
VITE_BIRDCODER_AUTH_DEV_DEFAULT_PASSWORD=dev123456
VITE_BIRDCODER_AUTH_DEV_DEFAULT_LOGIN_METHOD=password

# SDKWork cloud app-api IAM integration used when BIRDCODER_IAM_DEPLOYMENT_MODE=cloud-saas
# or SDKWORK_IAM_MODE=cloud.
# SDKWORK_IAM_APP_API_BASE_URL=https://app-api.sdkwork.com
# SDKWORK_IAM_APP_API_TIMEOUT_MS=8000
# SDKWORK_IAM_APP_ID=sdkwork-birdcoder
# SDKWORK_IAM_SECRET_ID=birdcoder-desktop
# SDKWORK_IAM_SHARED_SECRET=replace-with-shared-secret
# SDKWORK_IAM_APP_API_OAUTH_PROVIDERS=wechat,douyin,github

# Optional engine/application secrets retained from the existing workspace template.
# GEMINI_API_KEY=MY_GEMINI_API_KEY
# APP_URL=MY_APP_URL
