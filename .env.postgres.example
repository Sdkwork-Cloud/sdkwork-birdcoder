# SDKWork BirdCoder PostgreSQL 开发环境模板
# 复制为 .env.postgres 并填充本地数据库凭证
# 此文件已被 .gitignore 排除，不会提交到版本控制
# 生产环境凭证通过编排平台/容器环境变量注入

# =============================================================================
# PostgreSQL 数据库连接（应用读写数据使用）
# =============================================================================
SDKWORK_BIRDCODER_DATABASE_ENGINE=postgresql
SDKWORK_BIRDCODER_DATABASE_HOST=127.0.0.1
SDKWORK_BIRDCODER_DATABASE_PORT=5432
SDKWORK_BIRDCODER_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_BIRDCODER_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_BIRDCODER_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_BIRDCODER_DATABASE_PASSWORD=changeme
SDKWORK_BIRDCODER_DATABASE_SSL_MODE=disable
SDKWORK_BIRDCODER_DATABASE_MAX_CONNECTIONS=10

# =============================================================================
# 管理员连接（用于 DDL 变更 / 数据库初始化 / 迁移）
# =============================================================================
SDKWORK_BIRDCODER_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_BIRDCODER_DATABASE_ADMIN_PORT=5432
SDKWORK_BIRDCODER_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_BIRDCODER_DATABASE_ADMIN_PASSWORD=changeme
SDKWORK_BIRDCODER_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_BIRDCODER_DATABASE_ADMIN_SSL_MODE=disable

# Unified workspace PostgreSQL admin identity (ENVIRONMENT_SPEC §7.1).
# Required for pnpm db:postgres:init across SDKWork repositories.
SDKWORK_CLAW_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_ADMIN_PORT=5432
SDKWORK_CLAW_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_CLAW_DATABASE_ADMIN_PASSWORD=changeme
SDKWORK_CLAW_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_CLAW_DATABASE_ADMIN_SSL_MODE=disable
