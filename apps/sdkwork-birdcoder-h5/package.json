{
  "name": "@sdkwork/birdcoder-h5",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@sdkwork/birdcoder-h5-admin-core": "workspace:*",
    "@sdkwork/birdcoder-h5-capacitor": "workspace:*",
    "@sdkwork/birdcoder-h5-chat": "workspace:*",
    "@sdkwork/birdcoder-h5-commons": "workspace:*",
    "@sdkwork/birdcoder-h5-core": "workspace:*",
    "@sdkwork/birdcoder-h5-shell": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "tailwindcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:"
  },
  "devDependencies": {
    "@capacitor/cli": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "scripts": {
    "dev": "node ../../scripts/run-birdcoder-dev-stack.mjs h5 --iam-mode server-private",
    "dev:capacitor-ios": "cap sync && cap open ios",
    "dev:capacitor-android": "cap sync && cap open android",
    "build": "tsc && vite build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "node ../../scripts/h5-app-session-persistence-contract.test.mjs && node ../../scripts/h5-route-assembly-contract.test.mjs",
    "build:capacitor-android:sync": "pnpm --filter @sdkwork/birdcoder-h5-capacitor build:capacitor-android:sync",
    "build:capacitor-android:copy": "pnpm --filter @sdkwork/birdcoder-h5-capacitor build:capacitor-android:copy",
    "build:capacitor-ios": "cap sync && cap copy ios && cap open ios",
    "build:capacitor-ios:full": "tsc && vite build --mode production && cap sync && cap copy ios",
    "build:capacitor-android": "cap sync && cap copy android && cap open android",
    "build:capacitor-android:full": "tsc && vite build --mode production && cap sync && cap copy android",
    "start:browser": "vite",
    "start:browser:check": "vite --mode test",
    "dev:browser": "node ../../scripts/run-birdcoder-dev-stack.mjs h5 --iam-mode server-private",
    "build:local": "tsc && vite build --mode development",
    "build:cloud": "tsc && vite build --mode production",
    "build:test": "tsc && vite build --mode test",
    "build:staging": "tsc && vite build --mode staging",
    "dev:browser:standalone": "node ../../scripts/run-birdcoder-dev-stack.mjs h5 --iam-mode server-private --vite-mode development",
    "dev:browser:cloud": "vite --mode production"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
