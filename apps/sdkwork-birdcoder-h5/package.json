{
  "name": "@sdkwork/birdcoder-h5",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@sdkwork/birdcoder-h5-admin-core": "workspace:*",
    "@sdkwork/birdcoder-h5-capacitor": "workspace:*",
    "@sdkwork/birdcoder-h5-commons": "workspace:*",
    "@sdkwork/birdcoder-h5-core": "workspace:*",
    "@sdkwork/birdcoder-h5-shell": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "tailwindcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:"
  },
  "devDependencies": {
    "@capacitor/cli": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "scripts": {
    "dev": "vite",
    "dev:cap:ios": "cap sync && cap open ios",
    "dev:cap:android": "cap sync && cap open android",
    "build": "tsc && vite build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "node ../../scripts/h5-app-session-persistence-contract.test.mjs && node ../../scripts/h5-route-assembly-contract.test.mjs",
    "cap:sync": "pnpm --filter @sdkwork/birdcoder-h5-capacitor cap:sync",
    "cap:copy": "pnpm --filter @sdkwork/birdcoder-h5-capacitor cap:copy",
    "cap:ios:build": "cap sync && cap copy ios && cap open ios",
    "cap:ios:build:prod": "tsc && vite build --mode production && cap sync && cap copy ios",
    "cap:android:build": "cap sync && cap copy android && cap open android",
    "cap:android:build:prod": "tsc && vite build --mode production && cap sync && cap copy android",
    "h5:dev": "vite",
    "h5:build": "tsc && vite build",
    "h5:build:staging": "tsc && vite build --mode staging",
    "h5:build:prod": "tsc && vite build --mode production",
    "h5:preview": "vite preview",
    "build:local": "tsc && vite build --mode development",
    "build:cloud": "tsc && vite build --mode production",
    "build:test": "tsc && vite build --mode test",
    "build:staging": "tsc && vite build --mode staging",
    "dev:private": "vite --mode development",
    "dev:cloud": "vite --mode production",
    "cap:ios:dev": "cap sync && cap open ios",
    "cap:android:dev": "cap sync && cap open android"
  }
}
