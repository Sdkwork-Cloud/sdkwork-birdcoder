    "type": "capacitor-host-package",
    "root": "sdkwork-birdcoder/apps/sdkwork-birdcoder-h5/packages/sdkwork-birdcoder-h5-capacitor",
    "domain": "device",
    "capability": "mobile-host-adapters",
    "surface": "native-host",
