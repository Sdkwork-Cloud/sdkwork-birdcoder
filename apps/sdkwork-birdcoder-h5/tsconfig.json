{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@sdkwork/birdcoder-h5-*": ["packages/sdkwork-birdcoder-h5-*/src"],
      "@sdkwork/birdcoder-commons/*": ["../../packages/sdkwork-birdcoder-commons/src/*"],
      "@sdkwork/birdcoder-infrastructure/*": ["../../packages/sdkwork-birdcoder-infrastructure/src/*"],
      "@sdkwork/birdcoder-shell/*": ["../../packages/sdkwork-birdcoder-shell/src/*"],
      "@sdkwork/birdcoder-types/*": ["../../packages/sdkwork-birdcoder-types/src/*"],
      "@sdkwork/birdcoder-core": ["../../packages/sdkwork-birdcoder-core/src/index.ts"],
      "@sdkwork/birdcoder-iam": ["../../packages/sdkwork-birdcoder-iam/src/index.ts"],
      "@sdkwork/birdcoder-auth": ["../../packages/sdkwork-birdcoder-auth/src/index.ts"],
      "@sdkwork/birdcoder-user": ["../../packages/sdkwork-birdcoder-user/src/index.ts"]
    }
  },
  "include": ["src", "packages"],
  "exclude": ["node_modules", "dist"]
}
