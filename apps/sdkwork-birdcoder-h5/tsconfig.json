{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@sdkwork/birdcoder-h5-*": ["packages/sdkwork-birdcoder-h5-*/src"],
      "@sdkwork/birdcoder-pc-infrastructure": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/index.ts"],
      "@sdkwork/birdcoder-pc-shell-runtime": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-shell-runtime/src/index.ts"],
      "@sdkwork/birdcoder-commons/*": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-commons/src/*"],
      "@sdkwork/birdcoder-infrastructure/*": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/*"],
      "@sdkwork/birdcoder-shell/*": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-shell/src/*"],
      "@sdkwork/birdcoder-types/*": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-types/src/*"],
      "@sdkwork/birdcoder-core": ["packages/sdkwork-birdcoder-h5-core/src/index.ts"],
      "@sdkwork/birdcoder-iam": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-iam/src/index.ts"],
      "@sdkwork/birdcoder-auth": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-auth/src/index.ts"],
      "@sdkwork/birdcoder-user": ["../sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-user/src/index.ts"]
    }
  },
  "include": ["src", "packages"],
  "exclude": ["node_modules", "dist"]
}
