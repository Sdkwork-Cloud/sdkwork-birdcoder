# Primary source profiles live in ../../etc/topology. This file documents only
# safe PC development overrides and contains no production credentials.
#
# Deployment profile and runtime target are orthogonal selectors. A deployment
# profile is standalone or cloud; the runtime target identifies the process
# shape, such as browser, desktop, server, container, or test-runner.
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
SDKWORK_BIRDCODER_RUNTIME_TARGET=desktop
VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET=desktop

# Canonical BirdCoder application ingress. The topology profile materializes
# this value; set an override only when attaching to an explicit endpoint.
# SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240
# VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240

# Canonical SDKWork platform gateway for Agents, Skills, Documents, Prompts,
# IAM, Drive, Messaging, Membership, and Order dependency SDKs.
# SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
# VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900

# Optional BirdCoder SQLite override for standalone development. Production
# database credentials belong in a protected server-side secret source.
# SDKWORK_BIRDCODER_DATABASE_FILE=D:/data/sdkwork-birdcoder/birdcoder.sqlite3

# Optional dev auth form prefill (explicit opt-in; identity still comes from register/login APIs).
# VITE_BIRDCODER_AUTH_DEV_PREFILL_ENABLED=true
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_EMAIL=you@example.test
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_PASSWORD=your-dev-password
# VITE_BIRDCODER_AUTH_DEV_DEFAULT_LOGIN_METHOD=password

# Optional absolute or sqlite-relative starter project root for the standalone
# development sample. When omitted, BirdCoder seeds a deterministic absolute
# path beside the SQLite authority file:
# <sqlite-dir>/bootstrap-projects/<sqlite-file-stem>/project-default
# BIRDCODER_LOCAL_BOOTSTRAP_PROJECT_ROOT=D:/data/sdkwork-birdcoder/bootstrap/project-default

# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
