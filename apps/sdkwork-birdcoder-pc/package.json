{
  "name": "@sdkwork/birdcoder-pc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:standalone",
    "dev:browser:standalone": "pnpm exec sdkwork-app dev --root ../.. --runtime-target browser --deployment-profile standalone",
    "dev:browser:cloud": "pnpm exec sdkwork-app dev --root ../.. --runtime-target browser --deployment-profile cloud",
    "dev:test-runner": "pnpm exec sdkwork-app dev --root ../.. --runtime-target test-runner --deployment-profile standalone",
    "dev:desktop": "pnpm dev:desktop:standalone",
    "dev:desktop:standalone": "pnpm exec sdkwork-app dev --root ../.. --runtime-target desktop --deployment-profile standalone",
    "dev:desktop:cloud": "pnpm exec sdkwork-app dev --root ../.. --runtime-target desktop --deployment-profile cloud",
    "check:component-spec-paths": "node scripts/check-component-spec-canonical-paths.mjs",
    "typecheck": "node ../../scripts/run-local-typescript.mjs --noEmit",
    "build": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs --cwd apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web build --mode production",
    "build:dev": "node ../../scripts/run-workspace-package-script.mjs apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web build:dev",
    "build:test": "node ../../scripts/run-workspace-package-script.mjs apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web build:test",
    "build:prod": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs --cwd apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web build --mode production",
    "build:staging": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs --cwd apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web build --mode staging",
    "build:server": "node ../../scripts/run-birdcoder-server-build.mjs",
    "preview": "node ../../scripts/run-workspace-package-script.mjs apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web preview",
    "lint": "pnpm typecheck",
    "build:desktop": "node ../../scripts/run-workspace-package-script.mjs apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-desktop build:desktop",
    "test": "pnpm test:unit",
    "test:unit": "node ../../scripts/run-local-tsx.mjs ../../scripts/auth-surface-routing-contract.test.ts && node ../../scripts/run-workspace-package-script.mjs apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-workbench test",
    "test:e2e": "node ../../scripts/run-pc-playwright-e2e.mjs",
    "dev:standalone": "pnpm exec sdkwork-app dev --root ../.. --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --root ../.. --deployment-profile cloud",
    "stop": "pnpm exec sdkwork-app stop --root ../..",
    "check": "pnpm check:component-spec-paths && pnpm typecheck && pnpm test && pnpm build",
    "verify": "pnpm check",
    "clean": "node -e \"require('node:fs').rmSync('packages/sdkwork-birdcoder-pc-web/dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@sdkwork/iam-credential-entry": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
