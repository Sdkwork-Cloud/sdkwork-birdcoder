{
  "name": "@sdkwork/birdcoder-pc-commons",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./context/*": {
      "import": "./src/context/*.ts",
      "types": "./src/context/*.ts"
    },
    "./hooks/*": {
      "import": "./src/hooks/*.ts",
      "types": "./src/hooks/*.ts"
    },
    "./chat/*": {
      "import": "./src/chat/*.ts",
      "types": "./src/chat/*.ts"
    },
    "./contexts/*": {
      "import": "./src/contexts/*.ts",
      "types": "./src/contexts/*.ts"
    },
    "./theme/*": {
      "import": "./src/theme/*.ts",
      "types": "./src/theme/*.ts"
    },
    "./platform/fileSystem": {
      "import": "./src/platform/fileSystem.ts",
      "types": "./src/platform/fileSystem.ts"
    },
    "./terminal/*": {
      "import": "./src/terminal/*.ts",
      "types": "./src/terminal/*.ts"
    },
    "./storage/dataKernel": {
      "import": "./src/storage/dataKernel.ts",
      "types": "./src/storage/dataKernel.ts"
    },
    "./storage/localStore": {
      "import": "./src/storage/localStore.ts",
      "types": "./src/storage/localStore.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "node ../../../../scripts/run-local-typescript.mjs --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "catalog:",
    "@sdkwork/birdcoder-pc-codeengine": "workspace:*",
    "@sdkwork/birdcoder-pc-chat": "workspace:*",
    "@sdkwork/birdcoder-pc-i18n": "workspace:*",
    "@sdkwork/birdcoder-pc-infrastructure": "workspace:*",
    "@sdkwork/birdcoder-pc-infrastructure-runtime": "workspace:*",
    "@sdkwork/birdcoder-pc-types": "workspace:*",
    "@sdkwork/utils": "workspace:*",
    "@sdkwork/terminal-pc-infrastructure": "workspace:*",
    "@sdkwork/terminal-pc-shell": "workspace:*",
    "lucide-react": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}



