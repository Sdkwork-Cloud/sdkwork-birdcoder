{
  "name": "@sdkwork/birdcoder-pc-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "node ../../../../scripts/run-local-typescript.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/birdcoder-app-sdk": "workspace:*",
    "@sdkwork/birdcoder-pc-contracts-commons": "workspace:*",
    "@sdkwork/documents-app-sdk": "workspace:*",
    "@sdkwork/drive-app-sdk": "workspace:*",
