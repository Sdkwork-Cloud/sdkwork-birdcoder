{
  "name": "@sdkwork/birdcoder-pc-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "node ../../../../scripts/run-local-typescript.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/birdcoder-pc-types": "workspace:*",
    "@sdkwork/iam-app-sdk": "workspace:*",
    "@sdkwork/sdk-common": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./appSessionToken": "./src/appSessionToken.ts",
    "./appSessionEvents": "./src/appSessionEvents.ts",
    "./appSessionTokenManager": "./src/appSessionTokenManager.ts",
    "./appSessionPersistence": "./src/appSessionPersistence.ts",
    "./appSessionAuthRedirect": "./src/appSessionAuthRedirect.ts",
    "./birdCoderApiTransportError": "./src/birdCoderApiTransportError.ts",
    "./sdk": {
      "types": "./src/sdk/index.ts",
      "import": "./src/sdk/index.ts",
      "default": "./src/sdk/index.ts"
    },
    "./modules": {
      "types": "./src/modules/index.ts",
      "import": "./src/modules/index.ts",
      "default": "./src/modules/index.ts"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "import": "./src/host/index.ts",
      "default": "./src/host/index.ts"
    },
    "./session": {
      "types": "./src/session/index.ts",
      "import": "./src/session/index.ts",
      "default": "./src/session/index.ts"
    },
    "./composition": {
      "types": "./src/composition/index.ts",
      "import": "./src/composition/index.ts",
      "default": "./src/composition/index.ts"
    }
  }
}
