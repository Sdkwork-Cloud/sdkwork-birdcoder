    "@sdkwork/agents-app-sdk": "workspace:*",
    "@sdkwork/messaging-app-sdk": "workspace:*",
    "@sdkwork/prompts-app-sdk": "workspace:*",
    "@sdkwork/skills-app-sdk": "workspace:*",
    "@sdkwork/sdk-common": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "catalog:",
