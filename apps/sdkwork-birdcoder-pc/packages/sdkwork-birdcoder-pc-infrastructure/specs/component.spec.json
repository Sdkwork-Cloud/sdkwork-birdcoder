  "integration": {
    "authority": "This component composes generated SDK adapters and native host adapters; it owns no business database or domain record.",
    "dependencyPolicy": "BirdCoder-owned SDK clients use application.public-ingress. Agents, Skills, Prompts, IAM, Drive, Messaging, Membership, and Order clients use platform.api-gateway or an explicit dependency override with the shared TokenManager; cross-plane fallback is forbidden. Project documents remain unavailable until Agents exposes a canonical document composition slot.",
    "persistencePolicy": "Agent sessions, assistant items, prompts, skills, documents, and coding-workbench facts are never persisted by this package. Desktop IAM session credentials use only the operating-system credential store host port.",
    "transportPolicy": "Handwritten HTTP transports, raw auth headers, local SDK forks, projection repositories, local business SQL, ambiguous global SDK URLs, and connection-plane compatibility fallbacks are forbidden."
  },
