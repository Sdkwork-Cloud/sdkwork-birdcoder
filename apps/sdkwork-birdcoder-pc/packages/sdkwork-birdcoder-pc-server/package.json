{
  "name": "@sdkwork/birdcoder-pc-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start:server": "node ../../../../scripts/run-cargo.mjs run --manifest-path ../../../../Cargo.toml -p sdkwork-birdcoder-standalone-gateway",
    "release:build:server": "node ../../../../scripts/run-birdcoder-server-build.mjs",
    "dev:server:standalone": "node ../../../../scripts/run-birdcoder-server-command.mjs dev --iam-mode server-private",
    "dev:server:cloud": "node ../../../../scripts/run-birdcoder-server-command.mjs dev --iam-mode cloud-saas",
    "build:server:standalone": "node ../../../../scripts/run-birdcoder-server-command.mjs build --iam-mode server-private",
    "build:server:cloud": "node ../../../../scripts/run-birdcoder-server-command.mjs build --iam-mode cloud-saas",
    "lint": "node ../../../../scripts/run-local-typescript.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/birdcoder-pc-projection": "workspace:*",
    "@sdkwork/birdcoder-pc-codeengine": "workspace:*",
    "@sdkwork/birdcoder-pc-workbench": "workspace:*",
    "@sdkwork/birdcoder-pc-host-core": "workspace:*",
    "@sdkwork/birdcoder-pc-infrastructure": "workspace:*",
    "@sdkwork/birdcoder-pc-contracts-commons": "workspace:*",
    "@sdkwork/iam-contracts": "workspace:*",
    "@sdkwork/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
