# Renderer-visible canonical surfaces. The development server reads its proxy
# targets from the non-VITE SDKWORK_BIRDCODER_* keys materialized by topology.
SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240
VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=/__sdkwork/platform
