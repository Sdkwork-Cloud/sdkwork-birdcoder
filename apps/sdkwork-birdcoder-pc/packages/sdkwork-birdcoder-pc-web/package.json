{
  "name": "@sdkwork/birdcoder-pc-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start:browser": "node ../../../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3000 --mode development",
    "start:browser:check": "node ../../../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3000 --mode test",
    "release:build:browser": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "release:build:browser:debug": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode development",
    "release:build:browser:check": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode test",
    "release:build:browser:full": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "dev:browser:standalone": "node ../../../../scripts/run-birdcoder-dev-stack.mjs web --iam-mode server-private",
    "dev:browser:cloud": "node ../../../../scripts/run-birdcoder-web-command.mjs dev --iam-mode cloud-saas",
    "dev:test-runner": "node ../../../../scripts/run-birdcoder-dev-stack.mjs web --iam-mode server-private --vite-mode test",
    "build:browser:standalone": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "build:browser:cloud": "node ../../../../scripts/run-birdcoder-web-command.mjs build --iam-mode cloud-saas",
    "build:dev": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode development",
    "build:test": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode test",
    "build:prod": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "preview": "node ../../../../scripts/run-vite-host.mjs preview",
    "lint": "node ../../../../scripts/run-local-typescript.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/iam-credential-entry": "workspace:*",
    "@sdkwork/birdcoder-pc-distribution": "workspace:*",
    "@sdkwork/birdcoder-pc-host-core": "workspace:*",
    "@sdkwork/birdcoder-pc-shell": "workspace:*",
    "@sdkwork/birdcoder-pc-shell-runtime": "workspace:*",
    "@sdkwork/birdcoder-pc-ui-shell": "workspace:*",
    "qrcode": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "react-router-dom": "catalog:",
    "tailwindcss": "catalog:",
    "@tailwindcss/vite": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
