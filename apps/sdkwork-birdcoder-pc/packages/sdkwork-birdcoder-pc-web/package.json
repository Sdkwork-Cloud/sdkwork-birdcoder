    "build:prod:base": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "dev": "node ../../../../scripts/run-birdcoder-dev-stack.mjs web --iam-mode server-private",
    "dev:private": "node ../../../../scripts/run-birdcoder-dev-stack.mjs web --iam-mode server-private",
    "dev:cloud": "node ../../../../scripts/run-birdcoder-web-command.mjs dev --iam-mode cloud-saas",
    "dev:test": "node ../../../../scripts/run-birdcoder-dev-stack.mjs web --iam-mode server-private --vite-mode test",
    "build": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "build:private": "node ../../../../scripts/run-birdcoder-web-command.mjs build --iam-mode server-private",
    "build:cloud": "node ../../../../scripts/run-birdcoder-web-command.mjs build --iam-mode cloud-saas",
    "build:dev": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode development",
    "build:test": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode test",
    "build:prod": "node ../../../../scripts/prepare-shared-sdk-packages.mjs && node ../../../../scripts/run-vite-host.mjs build --mode production",
    "preview": "node ../../../../scripts/run-vite-host.mjs preview",
    "lint": "node ../../../../scripts/run-local-typescript.mjs --noEmit"
