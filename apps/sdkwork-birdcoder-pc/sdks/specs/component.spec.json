{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-birdcoder-sdk-family",
    "displayName": "SDKWork BirdCoder SDK Family",
    "version": "0.1.0",
    "type": "sdk-family",
    "root": "sdkwork-birdcoder/sdks",
    "domain": "platform",
    "capability": "sdk",
    "status": "standardizing",
    "languages": [
      "typescript",
      "rust"
    ],
    "generated": true,
    "private": true,
    "domainCatalogs": [
      "specs/domain-catalog.json"
    ],
    "manifests": [
      "sdkwork-birdcoder-app-sdk/sdk-manifest.json",
      "sdkwork-birdcoder-backend-sdk/sdk-manifest.json"
    ]
  },
  "canonicalSpecs": [
    {
      "file": "README.md",
      "path": "../../../sdkwork-specs/README.md",
      "purpose": "SDKWork root standards entrypoint."
    },
    {
      "file": "API_SPEC.md",
      "path": "../../../sdkwork-specs/API_SPEC.md",
      "purpose": "OpenAPI source-of-truth, app/backend surface, path, tag, operationId, error, auth, and version rules."
    },
    {
      "file": "SDK_SPEC.md",
      "path": "../../../sdkwork-specs/SDK_SPEC.md",
      "purpose": "SDK generation manifest, generated output, resource-style client surface, auth headers, and SDK verification rules."
    },
    {
      "file": "COMPONENT_SPEC.md",
      "path": "../../../sdkwork-specs/COMPONENT_SPEC.md",
      "purpose": "Local component specs directory and sdk-family manifest rules."
    },
    {
      "file": "DOCUMENTATION_SPEC.md",
      "path": "../../../sdkwork-specs/DOCUMENTATION_SPEC.md",
      "purpose": "README and generated SDK example documentation rules."
    },
    {
      "file": "TEST_SPEC.md",
      "path": "../../../sdkwork-specs/TEST_SPEC.md",
      "purpose": "Executable API, SDK, generated output, and documentation verification rules."
    },
    {
      "file": "DOMAIN_SPEC.md",
      "path": "../../../sdkwork-specs/DOMAIN_SPEC.md",
      "purpose": "Canonical domain ownership and iam/platform/intelligence naming rules."
    },
    {
      "file": "CODE_STYLE_SPEC.md",
      "path": "../../../sdkwork-specs/CODE_STYLE_SPEC.md",
      "purpose": "Authored source structure and generated code boundaries."
    },
    {
      "file": "NAMING_SPEC.md",
      "path": "../../../sdkwork-specs/NAMING_SPEC.md",
      "purpose": "Canonical SDKWork naming rules."
    },
    {
      "file": "MODULE_SPEC.md",
      "path": "../../../sdkwork-specs/MODULE_SPEC.md",
      "purpose": "Reusable module and package boundary rules."
    },
    {
      "file": "TYPESCRIPT_CODE_SPEC.md",
      "path": "../../../sdkwork-specs/TYPESCRIPT_CODE_SPEC.md",
      "purpose": "TypeScript and Node package rules."
    },
    {
      "file": "RUST_CODE_SPEC.md",
      "path": "../../../sdkwork-specs/RUST_CODE_SPEC.md",
      "purpose": "Rust crate and module rules."
    }
  ],
  "contracts": {
    "publicExports": [
      "@sdkwork/birdcoder-app-sdk",
      "@sdkwork/birdcoder-backend-sdk",
      "sdkwork_birdcoder_app_sdk",
      "sdkwork_birdcoder_backend_sdk"
    ],
    "runtimeEntrypoints": [
      "sdkwork-birdcoder-app-sdk/sdk-manifest.json",
      "sdkwork-birdcoder-backend-sdk/sdk-manifest.json",
      "package.json#scripts.sdk:generate",
      "package.json#scripts.check:sdk-family-standard",
      "package.json#scripts.check:sdk-family-generated"
    ],
    "sdkClients": [
      "@sdkwork/birdcoder-app-sdk#createBirdcoderAppSdkClient",
      "@sdkwork/birdcoder-backend-sdk#createBirdcoderBackendSdkClient",
      "sdkwork_birdcoder_app_sdk",
      "sdkwork_birdcoder_backend_sdk"
    ],
    "events": [],
    "domainCatalog": "specs/domain-catalog.json",
    "sdkDependencies": [
      {
        "workspace": "sdkwork-iam-app-sdk",
        "role": "appbase-app-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/app/v3/api",
        "apiAuthority": "sdkwork-iam-app-api",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/iam-app-sdk",
          "rust": "sdkwork-iam-app-sdk"
        }
      },
      {
        "workspace": "sdkwork-iam-backend-sdk",
        "role": "appbase-backend-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/backend/v3/api",
        "apiAuthority": "sdkwork-iam-backend-api",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/iam-backend-sdk",
          "rust": "sdkwork-iam-backend-sdk"
        }
      },
      {
        "workspace": "sdkwork-drive-app-sdk",
        "role": "drive-app-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/app/v3/api",
        "apiAuthority": "sdkwork-drive.app",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/drive-app-sdk",
          "rust": "sdkwork-drive-app-sdk-generated-rust"
        }
      },
      {
        "workspace": "sdkwork-messaging-app-sdk",
        "role": "messaging-app-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/app/v3/api",
        "apiAuthority": "sdkwork-messaging-app-api",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/messaging-app-sdk"
        }
      }
    ],
    "configKeys": [
      "sdkwork-birdcoder-app-sdk/sdk-manifest.json#standardProfile",
      "sdkwork-birdcoder-backend-sdk/sdk-manifest.json#standardProfile"
    ],
    "routeManifest": null,
    "generation": {
      "canonicalOpenApi": "deployments/server-windows/x64/openapi/coding-server-v1.json",
      "familyDiscovery": "sdks/*/sdk-manifest.json"
    }
  },
  "integration": {
    "authority": "OpenAPI documents under sdks/specs/openapi are the SDK source of truth and must follow API_SPEC.md.",
    "dependencyPolicy": "Consumers integrate through generated SDK package exports or injected service facades; raw HTTP, manual token headers, local DTO forks, and hand-edited generated output are forbidden.",
    "sdkPolicy": "Generation uses --standard-profile sdkwork-v3 and exposes resource-oriented clients derived from OpenAPI tags and dotted operationIds.",
    "iamPolicy": "IAM and auth capabilities use the canonical iam/auth API domains and Access-Token handling; retired legacy domain aliases are not allowed."
  },
  "verification": {
    "commands": [
      "pnpm check:sdk-family-standard",
      "pnpm sdk:generate",
      "pnpm check:sdk-family-generated"
    ]
  },
  "metadata": {
    "managedBy": "scripts/generate-birdcoder-sdk-family.mjs",
    "standardVersion": "2026-05-15"
  }
}
