  "integration": {
    "authority": "This PC composition root owns presentation and local host capability only; it owns no business database, dependency API, or generated transport.",
    "dependencyPolicy": "Remote capabilities use their generated owner App SDK through the application ingress or platform gateway with one global TokenManager; raw HTTP and copied SDK authority are forbidden.",
    "projectPolicy": "Project, composition, Session, Turn, Session Item, Interaction, Checkpoint, and Runtime Binding facts are canonical sdkwork-agents resources identified by one projectId.",
    "persistencePolicy": "Only allowlisted device state may persist locally. Agents, Skills, Documents, IM, IAM, Drive, Messaging, Membership, Order, and Prompts business records are never projected or cached as PC authority.",
    "messagePolicy": "Agents Session Items are AI-assistant facts; sdkwork-im Conversation and Message are human communication facts and must remain semantically distinct."
