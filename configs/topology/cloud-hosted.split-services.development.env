# BirdCoder topology profile: cloud-hosted + split-services + development

SDKWORK_BIRDCODER_HOSTING=cloud-hosted
SDKWORK_BIRDCODER_SERVICE_LAYOUT=split-services
SDKWORK_BIRDCODER_ENVIRONMENT=development
SDKWORK_BIRDCODER_PROFILE_ID=cloud-hosted.split-services.development

SDKWORK_BIRDCODER_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:10240
SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART=true

VITE_SDKWORK_BIRDCODER_HOSTING=cloud-hosted
VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:10240
VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
