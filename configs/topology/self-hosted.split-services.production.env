# BirdCoder topology profile: self-hosted + split-services + production

SDKWORK_BIRDCODER_HOSTING=self-hosted
SDKWORK_BIRDCODER_SERVICE_LAYOUT=split-services
SDKWORK_BIRDCODER_ENVIRONMENT=production
SDKWORK_BIRDCODER_PROFILE_ID=self-hosted.split-services.production

SDKWORK_BIRDCODER_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:10240
SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://birdcoder.local:10240

SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://api.local:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_BIRDCODER_HOSTING=self-hosted
VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=http://birdcoder.local:10240
VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://api.local:3900
