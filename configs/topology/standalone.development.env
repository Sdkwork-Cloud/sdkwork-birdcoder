# standalone.development
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
SDKWORK_BIRDCODER_ENVIRONMENT=development
SDKWORK_BIRDCODER_PROFILE_ID=standalone.development

# IAM development environment — enables dev authentication fallback so the
# local server skips manifest permission checks (birdcoder.*.read etc.)
# when the IAM permission catalog is not provisioned for SQLite.
SDKWORK_IM_ENVIRONMENT=dev
SDKWORK_ENV=dev
SDKWORK_ENVIRONMENT=development
SDKWORK_DEPLOYMENT_MODE=local

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART=false
