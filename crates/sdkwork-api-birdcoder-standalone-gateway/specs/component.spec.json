  "integration": {
    "authority": "The standalone gateway is a thin runtime host: it initializes process infrastructure, asks the host-neutral BirdCoder API assembly to build the router, and binds the single standalone listener. It owns no route, service, repository, Agents, IAM, or Provider behavior.",
    "databasePolicy": "The gateway enables the process-shared sdkwork-database pool before assembly startup; the BirdCoder assembly and database host own lifecycle and persistence composition.",
    "assemblyPolicy": "BirdCoder HTTP behavior is consumed only through sdkwork-api-birdcoder-assembly. The gateway must not depend directly on route crates or duplicate assembly implementation dependencies.",
    "securityPolicy": "The BirdCoder API assembly owns sdkwork-web-framework request context, authorization, CORS, and response policy; the gateway owns listener lifecycle only."
  },
