  "integration": {
    "authority": "The Tauri host owns native commands, local filesystem boundaries, device and host state, operating-system credential-store access, and embedded gateway startup. It owns no business database or Session domain.",
    "gatewayPolicy": "Business HTTP and agent workflows are executed through the embedded sdkwork-api-birdcoder-standalone-gateway and sdkwork-agents routes.",
    "persistencePolicy": "BirdCoder-owned device-state SQLite owns exactly one device_state_entry table. Its allowlist permits settings/app, project-device-mounts/<sha256>, and the internal desktop-runtime-location-identity/installation.v1 row only. Project, Session, Conversation, Message, and other business aggregates are forbidden. Dependency-owned local stores remain outside BirdCoder database ownership. IAM accessToken, authToken, refresh material, and persisted application-session payloads use only the operating-system credential store.",
    "securityPolicy": "Filesystem roots and native commands are explicitly registered with least-privilege Tauri permissions. Credential-store failures fail closed and never fall back to SQLite or plaintext storage."
  },
  "verification": {
