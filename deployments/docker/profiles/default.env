# Standalone BirdCoder server control plane. This template is not a cloud
# runner and does not enable arbitrary-code execution.
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
SDKWORK_BIRDCODER_ENVIRONMENT=production
SDKWORK_BIRDCODER_RUNTIME_TARGET=server
SDKWORK_BIRDCODER_SERVER_PORT=18989
SDKWORK_BIRDCODER_DATABASE_ENGINE=postgresql
# Supply the protected PostgreSQL URL through an untracked Compose override or secret injection.
SDKWORK_CLAW_DATABASE_URL=
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_prod
SDKWORK_BIRDCODER_ALLOWED_ORIGINS=https://birdcoder.example.invalid
SDKWORK_BIRDCODER_APP_ROOT=/opt/sdkwork-birdcoder
SDKWORK_OPENAPI_SNAPSHOT_PATH=/opt/sdkwork-birdcoder/openapi/birdcoder-app-api.openapi.json
SDKWORK_BIRDCODER_REALTIME_BACKEND=memory
SDKWORK_BIRDCODER_REDIS_ENABLED=false
