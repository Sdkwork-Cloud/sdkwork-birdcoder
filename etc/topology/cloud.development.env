# cloud.development
SDKWORK_DATABASE_TEMPORARY_ANY_POOL_EXCEPTION=true
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=cloud
SDKWORK_BIRDCODER_ENVIRONMENT=development
SDKWORK_BIRDCODER_RUNTIME_TARGET=server
SDKWORK_BIRDCODER_PROFILE_ID=cloud.development
SDKWORK_BIRDCODER_DATABASE_ENGINE=postgresql
SDKWORK_BIRDCODER_PC_DEV_BIND=127.0.0.1:5173
# Inject SDKWORK_CLAW_DATABASE_URL through an environment-private local overlay.
SDKWORK_BIRDCODER_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://birdcoder-dev.sdkwork.com:10240
SDKWORK_BIRDCODER_PROVIDER_RUNNER_ROOT=.runtime/cloud-development/project-workspaces

# IAM development environment — enables dev authentication fallback so the
# local server skips manifest permission checks (birdcoder.*.read etc.)
# when the IAM permission catalog is not provisioned for SQLite.
SDKWORK_IM_ENVIRONMENT=dev
SDKWORK_ENV=dev
SDKWORK_ENVIRONMENT=development
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=https://api.sdkwork.com
VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=https://api.sdkwork.com
VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
