SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=https://birdcoder.sdkwork.com
VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL=https://birdcoder.sdkwork.com
