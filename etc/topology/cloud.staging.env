# cloud.staging
SDKWORK_DATABASE_TEMPORARY_ANY_POOL_EXCEPTION=true
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=cloud
SDKWORK_BIRDCODER_ENVIRONMENT=staging
SDKWORK_BIRDCODER_RUNTIME_TARGET=server
SDKWORK_BIRDCODER_PROFILE_ID=cloud.staging
SDKWORK_BIRDCODER_DATABASE_ENGINE=postgresql
# Inject SDKWORK_CLAW_DATABASE_URL through a protected secret.
SDKWORK_BIRDCODER_ALLOWED_ORIGINS=https://birdcoder-staging.sdkwork.com
SDKWORK_BIRDCODER_PROVIDER_RUNNER_ROOT=/var/lib/sdkwork-birdcoder/staging-project-workspaces
SDKWORK_ENV=staging
SDKWORK_ENVIRONMENT=staging
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=https://api-staging.sdkwork.com
