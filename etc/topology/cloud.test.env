# cloud.test
SDKWORK_DATABASE_TEMPORARY_ANY_POOL_EXCEPTION=true
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=cloud
SDKWORK_BIRDCODER_ENVIRONMENT=test
SDKWORK_BIRDCODER_RUNTIME_TARGET=server
SDKWORK_BIRDCODER_PROFILE_ID=cloud.test
SDKWORK_BIRDCODER_DATABASE_ENGINE=postgresql
# Inject SDKWORK_BIRDCODER_DATABASE_URL through an environment-private overlay.
SDKWORK_BIRDCODER_ALLOWED_ORIGINS=https://birdcoder-test.sdkwork.com
SDKWORK_BIRDCODER_PROVIDER_RUNNER_ROOT=.runtime/cloud-test/project-workspaces
SDKWORK_ENV=test
SDKWORK_ENVIRONMENT=test
SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=https://api-test.sdkwork.com
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART=true
SDKWORK_API_CLOUD_GATEWAY_CONFIG=etc/sdkwork-api-cloud-gateway.birdcoder.test.toml
