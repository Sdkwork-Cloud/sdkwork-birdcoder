# standalone.production
SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE=standalone
SDKWORK_BIRDCODER_ENVIRONMENT=production
SDKWORK_BIRDCODER_RUNTIME_TARGET=server
SDKWORK_BIRDCODER_PROFILE_ID=standalone.production
SDKWORK_BIRDCODER_DATABASE_ENGINE=sqlite
SDKWORK_BIRDCODER_DATABASE_FILE=/var/lib/sdkwork-birdcoder/birdcoder.sqlite3
SDKWORK_BIRDCODER_ALLOWED_ORIGINS=https://birdcoder.sdkwork.com
SDKWORK_BIRDCODER_PROVIDER_RUNNER_ROOT=/var/lib/sdkwork-birdcoder/project-workspaces

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART=false
