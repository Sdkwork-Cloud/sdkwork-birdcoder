{
  "name": "@sdkwork/birdcoder-commons",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./shell": {
      "import": "./src/shell.ts",
      "types": "./src/shell.ts"
    },
    "./workbench": {
      "import": "./src/workbench.ts",
      "types": "./src/workbench.ts"
    },
    "./platform/fileSystem": {
      "import": "./src/utils/fileSystem.ts",
      "types": "./src/utils/fileSystem.ts"
    },
    "./storage/dataKernel": {
      "import": "./src/storage/dataKernel.ts",
      "types": "./src/storage/dataKernel.ts"
    },
    "./storage/localStore": {
      "import": "./src/storage/localStore.ts",
      "types": "./src/storage/localStore.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "catalog:",
    "lucide-react": "catalog:",
    "@sdkwork/birdcoder-types": "workspace:*",
    "@sdkwork/birdcoder-chat": "workspace:*",
    "@sdkwork/birdcoder-chat-codex": "workspace:*",
    "@sdkwork/birdcoder-chat-claude": "workspace:*",
    "@sdkwork/birdcoder-chat-gemini": "workspace:*",
    "@sdkwork/birdcoder-chat-opencode": "workspace:*",
    "@sdkwork/birdcoder-i18n": "workspace:*",
    "@sdkwork/birdcoder-infrastructure": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
