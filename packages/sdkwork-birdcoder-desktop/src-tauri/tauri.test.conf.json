{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork BirdCoder",
  "version": "0.1.0",
  "identifier": "com.sdkwork.birdcoder",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri:test",
    "beforeBuildCommand": "pnpm build:test",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1520"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork BirdCoder",
        "decorations": false,
        "center": true,
        "minWidth": 1200,
        "minHeight": 760,
        "width": 1440,
        "height": 960
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": "((mailto:\\\\w+)|(tel:\\\\w+)|(https?://\\\\w+).+|(file://.+)|([A-Za-z]:\\\\\\\\.+)|(\\\\\\\\\\\\\\\\.+))"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
