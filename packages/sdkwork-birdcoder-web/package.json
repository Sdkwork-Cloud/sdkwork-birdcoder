{
  "name": "@sdkwork/birdcoder-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3000 --mode development",
    "dev:test": "node ../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3000 --mode test",
    "build": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode production",
    "build:dev": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode development",
    "build:test": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode test",
    "build:prod": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode production",
    "preview": "node ../../scripts/run-vite-host.mjs preview",
    "lint": "node ../../scripts/run-local-typescript.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/birdcoder-distribution": "workspace:*",
    "@sdkwork/birdcoder-host-core": "workspace:*",
    "@sdkwork/birdcoder-shell": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
