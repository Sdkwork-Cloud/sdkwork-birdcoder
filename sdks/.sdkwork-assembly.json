{
  "schemaVersion": 1,
  "kind": "sdkwork.sdk.assembly",
  "name": "sdkwork-birdcoder-sdk-family",
  "displayName": "SDKWork BirdCoder SDK Family",
  "version": "0.1.0",
  "standardProfile": "sdkwork-v3",
  "sourceOfTruth": {
    "api": "../../../specs/API_SPEC.md",
    "sdk": "../../../specs/SDK_SPEC.md",
    "domain": "../../../specs/DOMAIN_SPEC.md",
    "component": "../../../specs/COMPONENT_SPEC.md",
    "canonicalOpenApi": "server/windows/x64/openapi/coding-server-v1.json",
    "domainCatalog": "specs/domain-catalog.json",
    "openapi": [
      "specs/openapi/birdcoder-app-v3.openapi.json",
      "specs/openapi/birdcoder-backend-v3.openapi.json"
    ]
  },
  "surfaces": [
    {
      "id": "birdcoder-app",
      "surface": "app",
      "apiPrefix": "/app/v3/api",
      "inputSpecPath": "sdks/specs/openapi/birdcoder-app-v3.openapi.json",
      "packageName": "@sdkwork/birdcoder-app-sdk",
      "version": "0.1.0",
      "standardProfile": "sdkwork-v3",
      "generator": {
        "name": "birdcoder-sdk-family-generator",
        "command": "node scripts/generate-birdcoder-sdk-family.mjs --surface app --standard-profile sdkwork-v3 --input sdks/specs/openapi/birdcoder-app-v3.openapi.json --typescript-output sdks/sdkwork-birdcoder-app-sdk/sdkwork-birdcoder-app-sdk-typescript --rust-output sdks/sdkwork-birdcoder-app-sdk/sdkwork-birdcoder-app-sdk-rust --package-name @sdkwork/birdcoder-app-sdk --crate-name sdkwork_birdcoder_app_sdk --api-prefix /app/v3/api",
        "standardProfile": "sdkwork-v3"
      },
      "outputs": [
        {
          "language": "typescript",
          "packageName": "@sdkwork/birdcoder-app-sdk",
          "path": "sdks/sdkwork-birdcoder-app-sdk/sdkwork-birdcoder-app-sdk-typescript"
        },
        {
          "language": "rust",
          "crateName": "sdkwork_birdcoder_app_sdk",
          "path": "sdks/sdkwork-birdcoder-app-sdk/sdkwork-birdcoder-app-sdk-rust"
        }
      ]
    },
    {
      "id": "birdcoder-backend",
      "surface": "backend",
      "apiPrefix": "/backend/v3/api",
      "inputSpecPath": "sdks/specs/openapi/birdcoder-backend-v3.openapi.json",
      "packageName": "@sdkwork/birdcoder-backend-sdk",
      "version": "0.1.0",
      "standardProfile": "sdkwork-v3",
      "generator": {
        "name": "birdcoder-sdk-family-generator",
        "command": "node scripts/generate-birdcoder-sdk-family.mjs --surface backend --standard-profile sdkwork-v3 --input sdks/specs/openapi/birdcoder-backend-v3.openapi.json --typescript-output sdks/sdkwork-birdcoder-backend-sdk/sdkwork-birdcoder-backend-sdk-typescript --rust-output sdks/sdkwork-birdcoder-backend-sdk/sdkwork-birdcoder-backend-sdk-rust --package-name @sdkwork/birdcoder-backend-sdk --crate-name sdkwork_birdcoder_backend_sdk --api-prefix /backend/v3/api",
        "standardProfile": "sdkwork-v3"
      },
      "outputs": [
        {
          "language": "typescript",
          "packageName": "@sdkwork/birdcoder-backend-sdk",
          "path": "sdks/sdkwork-birdcoder-backend-sdk/sdkwork-birdcoder-backend-sdk-typescript"
        },
        {
          "language": "rust",
          "crateName": "sdkwork_birdcoder_backend_sdk",
          "path": "sdks/sdkwork-birdcoder-backend-sdk/sdkwork-birdcoder-backend-sdk-rust"
        }
      ]
    }
  ],
  "verification": {
    "commands": [
      "pnpm check:sdk-family-standard",
      "pnpm generate:sdk:birdcoder",
      "pnpm check:sdk-family-generated"
    ]
  }
}
