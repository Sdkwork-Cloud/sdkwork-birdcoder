{
  "openapi": "3.1.0",
  "x-sdkwork-api-authority": "sdkwork-birdcoder-app-api",
  "x-sdkwork-owner": "sdkwork-birdcoder",
  "info": {
    "title": "SDKWork BirdCoder App API",
    "version": "0.1.0",
    "description": "Canonical BirdCoder stateless coding-workbench System App API authority."
  },
  "servers": [
    {
      "url": "/app/v3/api"
    }
  ],
  "tags": [
    {
      "name": "system",
      "description": "System descriptor, health, route catalog, and runtime metadata resources."
    }
  ],
  "paths": {
    "/app/v3/api/system/descriptor": {
      "get": {
        "operationId": "descriptor.retrieve",
        "summary": "Get BirdCoder application descriptor",
        "description": "Get the BirdCoder application descriptor. Requires an authenticated BirdCoder user session.",
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "BirdCoder application descriptor returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BirdCoderApplicationDescriptorEnvelope"
                }
              }
            }
          },
          "default": {
            "description": "Problem response envelope.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        },
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "x-sdkwork-auth-mode": "user",
        "x-sdkwork-data-scope": "platform",
        "x-sdkwork-deployment": "all",
        "x-sdkwork-domain": "system",
        "x-sdkwork-permission": "birdcoder.system-descriptor.read",
        "x-sdkwork-public": false,
        "x-sdkwork-resource": "birdcoder.system-descriptor",
        "x-sdkwork-surface": "app",
        "x-sdkwork-tenant-scope": "tenant",
        "x-sdkwork-api-authority": "sdkwork-birdcoder-app-api",
        "x-sdkwork-owner": "sdkwork-birdcoder",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "app-api"
      }
    },
    "/app/v3/api/system/health": {
      "get": {
        "operationId": "health.retrieve",
        "summary": "Get BirdCoder application health",
        "description": "Get BirdCoder application health. Requires an authenticated BirdCoder user session.",
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "Runtime health returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BirdCoderCoreHealthSummaryEnvelope"
                }
              }
            }
          },
          "default": {
            "description": "Problem response envelope.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        },
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "x-sdkwork-auth-mode": "user",
        "x-sdkwork-data-scope": "platform",
        "x-sdkwork-deployment": "all",
        "x-sdkwork-domain": "system",
        "x-sdkwork-permission": "birdcoder.system-health.read",
        "x-sdkwork-public": false,
        "x-sdkwork-resource": "birdcoder.system-health",
        "x-sdkwork-surface": "app",
        "x-sdkwork-tenant-scope": "tenant",
        "x-sdkwork-api-authority": "sdkwork-birdcoder-app-api",
        "x-sdkwork-owner": "sdkwork-birdcoder",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "app-api"
      }
    },
    "/app/v3/api/system/routes": {
      "get": {
        "operationId": "routes.list",
        "summary": "List unified API routes",
        "description": "List unified API routes. Requires an authenticated BirdCoder user session.",
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "Unified route catalog returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BirdCoderApiRouteCatalogEntryListEnvelope"
                }
              }
            }
          },
          "default": {
            "description": "Problem response envelope.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        },
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "x-sdkwork-auth-mode": "user",
        "x-sdkwork-data-scope": "platform",
        "x-sdkwork-deployment": "all",
        "x-sdkwork-domain": "system",
        "x-sdkwork-permission": "birdcoder.system-routes.read",
        "x-sdkwork-public": false,
        "x-sdkwork-resource": "birdcoder.system-routes",
        "x-sdkwork-surface": "app",
        "x-sdkwork-tenant-scope": "tenant",
        "x-sdkwork-api-authority": "sdkwork-birdcoder-app-api",
        "x-sdkwork-owner": "sdkwork-birdcoder",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "app-api"
      }
    },
    "/app/v3/api/system/runtime": {
      "get": {
        "operationId": "runtime.retrieve",
        "summary": "Get runtime metadata",
        "description": "Get runtime metadata. Requires an authenticated BirdCoder user session.",
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "Runtime metadata returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BirdCoderCoreRuntimeSummaryEnvelope"
                }
              }
            }
          },
          "default": {
            "description": "Problem response envelope.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        },
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "x-sdkwork-auth-mode": "user",
        "x-sdkwork-data-scope": "platform",
        "x-sdkwork-deployment": "all",
        "x-sdkwork-domain": "system",
        "x-sdkwork-permission": "birdcoder.system-runtime.read",
        "x-sdkwork-public": false,
        "x-sdkwork-resource": "birdcoder.system-runtime",
        "x-sdkwork-surface": "app",
        "x-sdkwork-tenant-scope": "tenant",
        "x-sdkwork-api-authority": "sdkwork-birdcoder-app-api",
        "x-sdkwork-owner": "sdkwork-birdcoder",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "app-api"
      }
    }
  },
  "components": {
    "schemas": {
      "BirdCoderApplicationDescriptorEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "item": {
                    "$ref": "#/components/schemas/BirdCoderApplicationDescriptor"
                  }
                },
                "required": [
                  "item"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "data"
            ],
            "additionalProperties": false
          }
        ]
      },
      "ProblemDetail": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          },
          "code": {
            "type": "integer",
            "minimum": 40001
          },
          "traceId": {
            "type": "string",
            "description": "Server-owned request correlation id."
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "code",
          "traceId"
        ],
        "additionalProperties": true
      },
      "BirdCoderCoreHealthSummaryEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "item": {
                    "$ref": "#/components/schemas/BirdCoderCoreHealthSummary"
                  }
                },
                "required": [
                  "item"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "data"
            ],
            "additionalProperties": false
          }
        ]
      },
      "BirdCoderApiRouteCatalogEntryListEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/BirdCoderApiRouteCatalogEntry"
                    }
                  },
                  "pageInfo": {
                    "$ref": "#/components/schemas/PageInfo"
                  }
                },
                "required": [
                  "items",
                  "pageInfo"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "data"
            ],
            "additionalProperties": false
          }
        ]
      },
      "BirdCoderCoreRuntimeSummaryEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "item": {
                    "$ref": "#/components/schemas/BirdCoderCoreRuntimeSummary"
                  }
                },
                "required": [
                  "item"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "data"
            ],
            "additionalProperties": false
          }
        ]
      },
      "SdkWorkApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "enum": [
              0
            ],
            "default": 0,
            "minimum": 0,
            "maximum": 0
          },
          "data": {
            "description": "Operation-specific payload typed per response schema."
          },
          "traceId": {
            "type": "string",
            "description": "Server-owned request correlation id."
          }
        },
        "required": [
          "code",
          "data",
          "traceId"
        ],
        "additionalProperties": false
      },
      "BirdCoderApplicationDescriptor": {
        "type": "object",
        "properties": {
          "apiVersion": {
            "type": "string"
          },
          "gateway": {
            "$ref": "#/components/schemas/BirdCoderApiGatewaySummary"
          },
          "hostMode": {
            "type": "string",
            "enum": [
              "web",
              "desktop",
              "server"
            ]
          },
          "moduleId": {
            "type": "string",
            "enum": [
              "sdkwork-birdcoder"
            ]
          },
          "openApiPath": {
            "type": "string"
          },
          "surfaces": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "app",
                "backend"
              ]
            }
          }
        },
        "required": [
          "apiVersion",
          "gateway",
          "hostMode",
          "moduleId",
          "openApiPath",
          "surfaces"
        ],
        "additionalProperties": false
      },
      "BirdCoderCoreHealthSummary": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "additionalProperties": false
      },
      "BirdCoderApiRouteCatalogEntry": {
        "type": "object",
        "properties": {
          "authMode": {
            "type": "string",
            "enum": [
              "host",
              "user",
              "admin"
            ]
          },
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string"
          },
          "surface": {
            "type": "string",
            "enum": [
              "app",
              "backend"
            ]
          },
          "summary": {
            "type": "string"
          },
          "openApiPath": {
            "type": "string"
          },
          "operationId": {
            "type": "string"
          }
        },
        "required": [
          "authMode",
          "method",
          "path",
          "surface",
          "summary",
          "openApiPath",
          "operationId"
        ],
        "additionalProperties": false
      },
      "PageInfo": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "offset",
              "cursor"
            ]
          },
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1
          },
          "totalItems": {
            "type": "string"
          },
          "totalPages": {
            "type": "integer",
            "minimum": 0
          },
          "nextCursor": {
            "type": "string"
          },
          "hasMore": {
            "type": "boolean"
          }
        },
        "required": [
          "mode"
        ],
        "additionalProperties": false
      },
      "BirdCoderCoreRuntimeSummary": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "minimum": 0
          },
          "configFileName": {
            "type": "string"
          }
        },
        "required": [
          "host",
          "port",
          "configFileName"
        ],
        "additionalProperties": false
      },
      "BirdCoderApiGatewaySummary": {
        "type": "object",
        "properties": {
          "docsPath": {
            "type": "string"
          },
          "liveOpenApiPath": {
            "type": "string"
          },
          "openApiPath": {
            "type": "string"
          },
          "routeCatalogPath": {
            "type": "string"
          },
          "routeCount": {
            "type": "integer",
            "minimum": 0
          },
          "routesBySurface": {
            "type": "object",
            "properties": {
              "app": {
                "type": "integer",
                "minimum": 0
              },
              "backend": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "app",
              "backend"
            ],
            "additionalProperties": false
          },
          "surfaces": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BirdCoderApiGatewaySurfaceSummary"
            }
          }
        },
        "required": [
          "docsPath",
          "liveOpenApiPath",
          "openApiPath",
          "routeCatalogPath",
          "routeCount",
          "routesBySurface",
          "surfaces"
        ],
        "additionalProperties": false
      },
      "BirdCoderApiGatewaySurfaceSummary": {
        "type": "object",
        "properties": {
          "authMode": {
            "type": "string",
            "enum": [
              "host",
              "user",
              "admin"
            ]
          },
          "basePath": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "enum": [
              "app",
              "backend"
            ]
          },
          "routeCount": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "authMode",
          "basePath",
          "description",
          "name",
          "routeCount"
        ],
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "AuthToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "AccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token",
        "description": "Signed JWT access_token compact serialization (header.payload.signature)."
      }
    }
  }
}
