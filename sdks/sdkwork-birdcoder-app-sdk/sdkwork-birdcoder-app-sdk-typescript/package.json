{
  "name": "@sdkwork/birdcoder-app-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "sdkwork": {
    "apiPrefix": "/app/v3/api",
    "generatedBy": "scripts/generate-birdcoder-sdk-family.mjs",
    "inputSpec": "sdks/specs/openapi/birdcoder-app-v3.openapi.json",
    "standardProfile": "sdkwork-v3",
    "surface": "app"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  }
}
