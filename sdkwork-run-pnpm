#!/usr/bin/env sh
set -eu

if [ "$#" -eq 0 ]; then
  printf '%s\n' 'Usage: sdkwork-run-pnpm <pnpm-args...>' >&2
  exit 1
fi

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

if [ -n "${npm_execpath:-}" ] && [ -f "$npm_execpath" ]; then
  exec "$SCRIPT_DIR/sdkwork-run-node" "$npm_execpath" "$@"
fi

if [ -n "${PNPM_HOME:-}" ] && [ -x "$PNPM_HOME/pnpm" ]; then
  exec "$PNPM_HOME/pnpm" "$@"
fi

if command -v pnpm >/dev/null 2>&1; then
  exec pnpm "$@"
fi

printf '%s\n' 'pnpm is not available in the current script environment.' >&2
exit 1
