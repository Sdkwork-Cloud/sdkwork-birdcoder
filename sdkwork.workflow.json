    },
    {
      "id": "container-x64-server-amd-rocm-helm",
      "profile": "server",
      "platform": "container",
      "architecture": "x64",
      "variant": "amd-rocm",
      "formats": ["helm"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["artifacts/release/**/*"]
    },
    {
      "id": "container-arm64-server-cpu-helm",
      "profile": "server",
