      "formats": ["helm"],
      "runner": "ubuntu-24.04-arm",
      "outputGlobs": ["artifacts/release/**/*"]
    }
  ],
  "security": {
    "oidcRequired": true,
    "artifactAttestations": true,
    "sbomRequired": false,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": true,
    "aggregateRelease": true,
    "aggregateArtifactPath": "release-assets",
    "aggregateUploadGlobs": ["release-assets/**/*"],
    "retentionDays": 30
  }
}
