  "toolchains": {
    "node": "22",
    "pnpm": "10.30.2",
    "rust": "1.90.0",
    "wix": "5.0.2"
  },
  "lifecycle": {
    "preflight": [
      {
        "name": "Run BirdCoder package preflight",
        "shell": "node",
        "run": "node scripts/release/sdkwork-workflow-lifecycle.mjs preflight"
      }
    ],
    "install": [
      {
        "name": "Install BirdCoder workspace dependencies",
        "shell": "node",
        "run": "node scripts/release/sdkwork-workflow-lifecycle.mjs install"
      }
    ],
    "build": [
      {
        "name": "Build selected BirdCoder release target",
        "shell": "node",
        "run": "node scripts/release/sdkwork-workflow-lifecycle.mjs build"
      }
    ],
    "package": [
      {
        "name": "Package selected BirdCoder release target",
        "shell": "node",
        "run": "node scripts/release/sdkwork-workflow-lifecycle.mjs package"
      }
    ],
    "validate": [
      {
        "name": "Validate selected BirdCoder release target",
        "shell": "node",
        "run": "node scripts/release/sdkwork-workflow-lifecycle.mjs validate"
      }
    ],
    "publish": [
      {
        "name": "Finalize BirdCoder aggregate release assets",
        "shell": "node",
        "run": "node scripts/release/sdkwork-workflow-lifecycle.mjs publish"
      }
    ]
  },
