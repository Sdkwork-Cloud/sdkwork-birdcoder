{
  "schemaVersion": 2,
  "kind": "sdkwork.agents-birdcoder-alignment",
  "updatedAt": "2026-07-22",
  "summary": "BirdCoder consumes the canonical Agents session system through generated SDK clients and owns no parallel session, transcript, interaction, runtime, artifact, or checkpoint authority.",
  "authorityDocs": [
    "docs/architecture/tech/TECH_ARCHITECTURE.md",
    "docs/product/prd/PRD.md",
    "specs/domain-ownership.spec.json",
    "specs/agent-session-item-view.spec.md"
  ],
  "dependencyDirection": [
    "sdkwork-birdcoder -> sdkwork-agents -> sdkwork-kernel",
    "sdkwork-im -> sdkwork-agents -> sdkwork-kernel",
    "sdkwork-agents -/-> sdkwork-im"
  ],
  "tasks": [
    {
      "id": "ABA-001",
      "owner": "agents",
      "title": "Use the canonical Agents domain and session contracts",
      "status": "done",
      "gate": true,
      "evidence": {
        "siblingPaths": [
          "../sdkwork-agents/specs/AGENTS_DOMAIN_SPEC.md",
          "../sdkwork-agents/specs/AGENTS_SESSION_MODEL_SPEC.md",
          "../sdkwork-agents/specs/AGENTS_IM_DEPENDENCY_BOUNDARY_SPEC.md",
          "../sdkwork-agents/sdks/sdkwork-agents-app-sdk/sdkwork-agents-app-sdk-typescript/package.json"
        ]
      },
      "verification": {
        "commands": [
          "pnpm check:agents-birdcoder-alignment"
        ]
      }
    },
    {
      "id": "ABA-002",
      "owner": "birdcoder",
      "title": "Inject the generated Agents App SDK from the PC composition root",
      "status": "done",
      "gate": true,
      "evidence": {
        "paths": [
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/services/agentsSdkClients.ts",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/services/agentsCatalogService.ts"
        ],
        "requiredPatterns": [
          {
            "file": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/services/agentsSdkClients.ts",
            "pattern": "getBirdCoderGlobalTokenManager"
          },
          {
            "file": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/services/agentsCatalogService.ts",
            "pattern": "client\\.ai\\.agents"
          }
        ],
        "forbiddenPatterns": [
          {
            "file": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/services/agentsSdkClients.ts",
            "pattern": "fetch\\(|Authorization|Bearer "
          }
        ]
      },
      "verification": {
        "commands": [
          "pnpm check:api-transport-standard"
        ]
      }
    },
    {
      "id": "ABA-003",
      "owner": "birdcoder",
      "title": "Remove all BirdCoder-owned duplicate Agents authorities",
      "status": "done",
      "gate": true,
      "evidence": {
        "forbiddenPaths": [
          "apps/sdkwork-birdcoder-common/packages/sdkwork-birdcoder-chat-contracts",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-codeengine",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-projection",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-contracts-commons/src/coding-session.ts",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-contracts-commons/src/generated/coding-server-client.ts",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-contracts-commons/src/generated/coding-server-openapi.ts",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/services/codingSessionMessageProjection.ts",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-infrastructure/src/storage/codingSessionRepository.ts"
        ]
      },
      "verification": {
        "commands": [
          "pnpm check:domain-ownership"
        ]
      }
    },
    {
      "id": "ABA-004",
      "owner": "birdcoder",
      "title": "Keep AI transcript and human IM semantics separate",
      "status": "done",
      "gate": true,
      "evidence": {
        "paths": [
          "specs/agent-session-item-view.spec.md",
          "docs/architecture/tech/TECH_ARCHITECTURE.md"
        ],
        "requiredPatterns": [
          {
            "file": "specs/agent-session-item-view.spec.md",
            "pattern": "Session Item"
          },
          {
            "file": "specs/agent-session-item-view.spec.md",
            "pattern": "human Conversation, Message, Member, and ReadCursor"
          }
        ]
      },
      "verification": {
        "commands": [
          "pnpm check:agents-birdcoder-alignment"
        ]
      }
    }
  ],
  "verificationMatrix": {
    "commands": [
      "pnpm check:domain-ownership",
      "pnpm check:agents-birdcoder-alignment",
      "pnpm check:kernel-birdcoder-alignment",
