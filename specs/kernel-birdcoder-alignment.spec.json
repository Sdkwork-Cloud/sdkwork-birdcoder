{
  "schemaVersion": 2,
  "kind": "sdkwork.kernel-birdcoder-boundary",
  "updatedAt": "2026-07-22",
  "summary": "BirdCoder consumes agent execution through sdkwork-agents and never integrates sdkwork-kernel directly.",
  "authorityDocs": [
    "docs/architecture/tech/TECH_ARCHITECTURE.md",
    "docs/product/prd/PRD.md",
    "specs/domain-ownership.spec.json"
  ],
  "dependencyDirection": [
    "sdkwork-birdcoder -> sdkwork-agents -> sdkwork-kernel",
    "sdkwork-birdcoder -/-> sdkwork-kernel"
  ],
  "siblingDependencies": [],
  "tasks": [
    {
      "id": "KBB-001",
      "phase": "boundary",
      "owner": "birdcoder",
      "title": "Remove BirdCoder-owned Kernel bridges and code-engine authorities",
      "status": "done",
      "gate": true,
      "evidence": {
        "forbiddenPaths": [
          "crates/sdkwork-birdcoder-kernel-bridge",
          "crates/sdkwork-birdcoder-codeengine",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-codeengine",
          "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-projection"
        ]
      },
      "verification": {
        "commands": [
          "pnpm check:domain-ownership"
        ]
      }
    },
    {
      "id": "KBB-002",
      "phase": "boundary",
      "owner": "birdcoder",
      "title": "Keep Kernel ownership and provider bindings outside BirdCoder",
      "status": "done",
      "gate": true,
      "evidence": {
        "paths": [
          "specs/domain-ownership.spec.json",
          "docs/architecture/tech/TECH_ARCHITECTURE.md"
        ],
        "forbiddenPatterns": [
          {
            "file": "Cargo.toml",
            "pattern": "sdkwork[-_]kernel|sdkwork-agent-kernel|sdkwork-code-kernel"
          },
          {
            "file": "package.json",
            "pattern": "@sdkwork/kernel|birdcoder-kernel-bridge|birdcoder-pc-codeengine"
          }
        ]
      },
      "verification": {
        "commands": [
          "pnpm check:kernel-birdcoder-alignment"
        ]
      }
    }
  ],
  "verificationMatrix": {
    "alignmentLoop": [
      "pnpm check:domain-ownership",
      "pnpm check:kernel-birdcoder-alignment",
      "pnpm check:arch"
    ],
    "governanceSubset": [
      "pnpm run check:domain-ownership"
    ]
  }
}
