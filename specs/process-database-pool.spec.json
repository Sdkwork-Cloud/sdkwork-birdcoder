{
  "schemaVersion": 1,
  "kind": "sdkwork.process-database-pool",
  "profile": {
    "exampleFile": ".env.postgres.example",
    "database": "sdkwork_ai_dev",
    "schema": "sdkwork_ai_dev"
  },
  "processes": [
    {
      "id": "sdkwork-api-birdcoder-standalone-gateway",
      "entrypoint": "crates/sdkwork-api-birdcoder-standalone-gateway/src/main.rs",
      "poolOwner": "crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/database.rs",
      "driver": "sqlx::PgPool",
      "poolCount": 1,
      "databaseUrlEnv": "SDKWORK_CLAW_DATABASE_*",
      "schemaEnv": "SDKWORK_CLAW_DATABASE_SCHEMA",
      "maxConnectionsEnv": "SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS",
      "productionSourceRoots": [
        "crates/sdkwork-api-birdcoder-standalone-gateway/src",
        "crates/sdkwork-api-birdcoder-assembly/src"
      ],
      "consumers": [
        {
          "module": "sdkwork-birdcoder lifecycle",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/database.rs"]
        },
        {
          "module": "sdkwork-iam",
          "poolMode": "installed-process-pool",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/iam.rs"]
        },
        {
          "module": "sdkwork-birdcoder repositories",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/repositories.rs"]
        },
        {
          "module": "sdkwork-drive",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/bootstrap.rs"]
        },
        {
          "module": "sdkwork-membership",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/bootstrap.rs"]
        }
      ],
      "temporaryDriverExceptions": [
        {
          "driver": "sqlx::AnyPool",
          "owner": "sdkwork-birdcoder repository maintainers",
          "removalMilestone": "Migrate Birdcoder production repositories to sqlx::PgPool before public launch",
          "combinedConnectionBudget": 15,
          "adr": "docs/architecture/decisions/ADR-20260719-birdcoder-repository-pool-driver-migration.md",
          "evidence": ["crates/sdkwork-birdcoder-sqlx-repository-pool/src/lib.rs"]
        }
      ]
    },
    {
      "id": "sdkwork-birdcoder-pc-server-host-shim",
      "entrypoint": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-server/src-host/src/main.rs",
      "poolOwner": "crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/database.rs",
      "driver": "sqlx::PgPool",
      "poolCount": 1,
      "databaseUrlEnv": "SDKWORK_CLAW_DATABASE_*",
      "schemaEnv": "SDKWORK_CLAW_DATABASE_SCHEMA",
      "maxConnectionsEnv": "SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS",
      "productionSourceRoots": [
        "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-server/src-host/src",
        "crates/sdkwork-api-birdcoder-standalone-gateway/src",
        "crates/sdkwork-api-birdcoder-assembly/src"
      ],
      "consumers": [
        {
          "module": "sdkwork-birdcoder standalone host",
          "poolMode": "installed-process-pool",
          "evidence": ["apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-server/src-host/src/main.rs"]
        },
        {
          "module": "sdkwork-birdcoder repositories",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/repositories.rs"]
        },
        {
          "module": "sdkwork-iam",
          "poolMode": "installed-process-pool",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/iam.rs"]
        },
        {
          "module": "sdkwork-drive",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/bootstrap.rs"]
        },
        {
          "module": "sdkwork-membership",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/bootstrap.rs"]
        }
      ],
      "temporaryDriverExceptions": [
        {
          "driver": "sqlx::AnyPool",
          "owner": "sdkwork-birdcoder repository maintainers",
          "removalMilestone": "Migrate Birdcoder production repositories to sqlx::PgPool before public launch",
          "combinedConnectionBudget": 15,
          "adr": "docs/architecture/decisions/ADR-20260719-birdcoder-repository-pool-driver-migration.md",
          "evidence": ["crates/sdkwork-birdcoder-sqlx-repository-pool/src/lib.rs"]
        }
      ]
    }
  ],
  "verification": [
    "node ../sdkwork-specs/tools/check-process-shared-database-pool.mjs --root .",
    "cargo test -p sdkwork-api-birdcoder-standalone-gateway"
  ]
}
