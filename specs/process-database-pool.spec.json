{
  "schemaVersion": 1,
  "kind": "sdkwork.process-database-pool",
  "profile": {
    "exampleFile": ".env.postgres.example",
    "database": "sdkwork_ai_dev",
    "schema": "sdkwork_ai_dev"
  },
  "processes": [
    {
      "id": "sdkwork-api-birdcoder-standalone-gateway",
      "entrypoint": "crates/sdkwork-api-birdcoder-standalone-gateway/src/main.rs",
      "poolOwner": "crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/database.rs",
      "driver": "sdkwork_database_sqlx::DatabasePool",
      "poolCount": 1,
      "databaseUrlEnv": "SDKWORK_CLAW_DATABASE_*",
      "schemaEnv": "SDKWORK_CLAW_DATABASE_SCHEMA",
      "maxConnectionsEnv": "SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS",
      "productionSourceRoots": [
        "crates/sdkwork-api-birdcoder-standalone-gateway/src",
        "crates/sdkwork-api-birdcoder-assembly/src"
      ],
      "consumers": [
        {
          "module": "sdkwork-birdcoder database lifecycle",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-birdcoder-database-host/src/lib.rs"]
        },
        {
          "module": "sdkwork-birdcoder repositories",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/application_bootstrap/repositories.rs"]
        },
        {
          "module": "sdkwork-birdcoder health readiness",
          "poolMode": "injected",
          "evidence": ["crates/sdkwork-api-birdcoder-assembly/src/health.rs"]
        }
      ],
      "temporaryDriverExceptions": []
    }
  ],
  "verification": [
    "node ../sdkwork-specs/tools/check-process-shared-database-pool.mjs --root .",
    "cargo test -p sdkwork-api-birdcoder-standalone-gateway"
  ]
}
