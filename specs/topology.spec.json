{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-birdcoder",
  "archetype": "application-http-gateway",
  "profileRoot": "etc/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "environment": {
      "allowed": [
        "development",
        "test",
        "staging",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.development": "etc/topology/standalone.development.env",
    "standalone.test": "etc/topology/standalone.test.env",
    "standalone.staging": "etc/topology/standalone.staging.env",
    "standalone.production": "etc/topology/standalone.production.env",
    "cloud.development": "etc/topology/cloud.development.env",
    "cloud.test": "etc/topology/cloud.test.env",
    "cloud.staging": "etc/topology/cloud.staging.env",
    "cloud.production": "etc/topology/cloud.production.env"
  },
  "envKeys": {
    "environment": "SDKWORK_BIRDCODER_ENVIRONMENT",
    "profileId": "SDKWORK_BIRDCODER_PROFILE_ID",
    "apiGatewayBaseUrl": "SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
    "deploymentProfile": "SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_BIRDCODER_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "birdcoder.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-api-birdcoder-standalone-gateway",
      "binary": "sdkwork-api-birdcoder-standalone-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-api-birdcoder-standalone-gateway",
            "binary": "sdkwork-api-birdcoder-standalone-gateway",
            "runtimeTargets": [
              "browser",
              "desktop",
              "server",
              "test-runner",
              "capacitor-ios",
              "capacitor-android"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "server"
            },
            "required": true,
            "role": "api-standalone-gateway"
          },
          {
            "id": "pc-web-renderer",
            "package": "@sdkwork/birdcoder-pc-web",
            "script": "start:browser",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          },
          {
            "id": "h5-browser-renderer",
            "package": "@sdkwork/birdcoder-h5",
            "script": "start:browser",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "h5"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_RUNTIME_TARGET": "h5"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          },
          {
            "id": "h5-capacitor-renderer",
            "package": "@sdkwork/birdcoder-h5",
            "script": "start:browser",
            "runtimeTargets": [
              "capacitor-ios",
              "capacitor-android"
            ],
            "clientArchitectures": [
              "capacitor"
            ],
            "env": {
              "VITE_SDKWORK_RUNTIME_TARGET": "capacitor"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          },
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          },
          {
            "id": "pc-web-test-runner",
            "package": "@sdkwork/birdcoder-pc-web",
            "script": "start:browser:check",
            "runtimeTargets": [
              "test-runner"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "test-runner",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "test-runner"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [
          {
            "id": "pc-web-renderer",
            "package": "@sdkwork/birdcoder-pc-web",
            "script": "start:browser",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          },
          {
            "id": "h5-browser-renderer",
            "package": "@sdkwork/birdcoder-h5",
            "script": "start:browser",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "h5"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_RUNTIME_TARGET": "h5"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          },
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          },
          {
            "id": "pc-web-test-runner",
            "package": "@sdkwork/birdcoder-pc-web",
            "script": "start:browser:check",
            "runtimeTargets": [
              "test-runner"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "test-runner",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "test-runner"
            },
            "bindEnv": "SDKWORK_BIRDCODER_PC_DEV_BIND",
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-api-birdcoder-standalone-gateway",
            "binary": "sdkwork-api-birdcoder-standalone-gateway",
            "runtimeTargets": [
              "server",
              "container"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "server"
            },
            "required": true,
            "role": "api-standalone-gateway"
          },
          {
            "id": "pc-web-renderer",
            "package": "@sdkwork/birdcoder-pc-web",
            "script": "start:browser",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "browser"
            },
            "required": false,
            "role": "client"
          },
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": false,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": []
      },
      "standalone.test": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": []
      },
      "standalone.staging": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": []
      },
      "cloud.test": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway"
        ]
      },
      "cloud.staging": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "@sdkwork/birdcoder-pc-desktop",
            "script": "start:desktop",
            "runtimeTargets": [
              "desktop"
            ],
            "clientArchitectures": [
              "tauri"
            ],
            "env": {
              "SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop",
              "VITE_SDKWORK_BIRDCODER_RUNTIME_TARGET": "desktop"
            },
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway"
        ]
      }
    }
  },
  "retired": {
    "vocabulary": {
      "topology": [
        "standalone",
        "cloud"
      ],
      "profile": [
        "development",
        "production"
      ],
      "hosting": [
        "self-hosted",
        "cloud-hosted"
      ]
    },
    "envKeys": [
      "SDKWORK_BIRDCODER_TOPOLOGY",
      "VITE_BIRDCODER_TOPOLOGY",
      "VITE_BIRDCODER_TOPOLOGY",
      "SDKWORK_BIRDCODER_HOSTING",
      "VITE_SDKWORK_BIRDCODER_HOSTING"
    ],
    "cliFlags": [
      "--topology"
    ]
  },
  "packaging": {
    "cloudConfigFiles": [],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-birdcoder-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
