{
  "schemaVersion": 4,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-birdcoder",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.development": "configs/topology/standalone.development.env",
    "standalone.production": "configs/topology/standalone.production.env",
    "cloud.development": "configs/topology/cloud.development.env",
    "cloud.production": "configs/topology/cloud.production.env"
  },
  "envKeys": {
    "environment": "SDKWORK_BIRDCODER_ENVIRONMENT",
    "profileId": "SDKWORK_BIRDCODER_PROFILE_ID",
    "gatewayAutostart": "SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART",
    "cloudGatewayBind": "SDKWORK_API_CLOUD_GATEWAY_BIND",
    "apiGatewayBaseUrl": "SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
    "deploymentProfile": "SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_SDKWORK_BIRDCODER_DEPLOYMENT_PROFILE"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_BIRDCODER_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_BIRDCODER_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "owner": "sdkwork-api-cloud-gateway",
      "bindEnv": "SDKWORK_API_CLOUD_GATEWAY_BIND",
      "httpUrlEnv": "SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_HTTP_URL",
      "autostartEnv": "SDKWORK_BIRDCODER_PLATFORM_API_GATEWAY_AUTOSTART"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "birdcoder.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_BIRDCODER"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-birdcoder-standalone-gateway",
      "binary": "sdkwork-birdcoder-standalone-gateway"
    },
    "cloudGateway": {
      "crate": "sdkwork-api-cloud-gateway",
      "binary": "sdkwork-api-cloud-gateway",
      "repository": "sdkwork-api-cloud-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-desktop",
            "script": "tauri:dev:base",
            "required": true
          }
        ],
        "healthSurfaces": []
      },
      "cloud.development": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          },
          {
            "id": "application.public-ingress",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-server",
            "script": "dev:base",
            "required": true
          },
          {
            "id": "pc-web-renderer",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web",
            "script": "dev:base",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          },
          {
            "id": "application.public-ingress",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-server",
            "script": "dev:base",
            "required": true
          },
          {
            "id": "pc-web-renderer",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-web",
            "script": "dev:base",
            "required": false
          },
          {
            "id": "pc-desktop-renderer",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-desktop",
            "script": "tauri:dev:base",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "pc-desktop-renderer",
            "package": "apps/sdkwork-birdcoder-pc/packages/sdkwork-birdcoder-pc-desktop",
            "script": "tauri:dev:base",
            "required": true
          }
        ],
        "healthSurfaces": []
      }
    }
  },
  "scripts": {
    "birdcoderDev": "scripts/birdcoder-dev.mjs"
  },
  "retired": {
    "vocabulary": {
      "topology": [
        "standalone",
        "cloud"
      ],
      "profile": [
        "development",
        "production"
      ],
      "hosting": [
        "self-hosted",
        "cloud-hosted"
      ]
    },
    "envKeys": [
      "SDKWORK_BIRDCODER_TOPOLOGY",
      "VITE_BIRDCODER_TOPOLOGY",
      "VITE_BIRDCODER_TOPOLOGY",
      "SDKWORK_BIRDCODER_HOSTING",
      "VITE_SDKWORK_BIRDCODER_HOSTING"
    ],
    "cliFlags": [
      "--topology"
    ]
  },
  "packaging": {
    "cloudConfigFiles": [
      "sdkwork-api-cloud-gateway.birdcoder.development.toml",
      "sdkwork-api-cloud-gateway.birdcoder.production.toml"
    ],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-birdcoder-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
