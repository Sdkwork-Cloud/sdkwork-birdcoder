{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@sdkwork/birdcoder-commons/shell": [
        "packages/sdkwork-birdcoder-commons/src/shell.ts"
      ],
      "@sdkwork/birdcoder-*": [
        "packages/sdkwork-birdcoder-*/src"
      ],
      "sdkwork-birdcoder-commons/shell": [
        "packages/sdkwork-birdcoder-commons/src/shell.ts"
      ],
      "sdkwork-birdcoder-*": [
        "packages/sdkwork-birdcoder-*/src"
      ]
    }
  },
  "include": [
    "src",
    "packages",
    "scripts"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/target/**",
    "**/src-tauri/target/**",
    "artifacts/**"
  ]
}
